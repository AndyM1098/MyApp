@model Student

@{
    ViewData["Title"] = "Intro";
}

<section class="hero">
    <p class="eyebrow">Welcome</p>
    <h1>Building ideas into polished web experiences.</h1>
    <p class="lead">
        This is your intro page. Use it to quickly explain what you build,
        what technologies you use, and where visitors should click next.
    </p>
    <div class="hero-actions">
        <a class="btn" asp-controller="Home" asp-action="Projects">View Projects</a>
        <a class="btn btn-ghost" asp-controller="Home" asp-action="About">About Me</a>
    </div>
</section>

@if (Model != null)
{
    <section class="panel">
        <h2>Quick Demo Data</h2>
        <p>This card is populated from your C# model and controller.</p>

        <div class="grid-two">
            <div>
                <p><strong>Name:</strong> @Model.Name</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Display:</strong> @Model.GetDisplayName()</p>
            </div>
            <div>
                <p><strong>Student ID:</strong> @Model.StudentId</p>
                <p><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</p>
                <p><strong>Status:</strong> @(Model.IsActive ? "Active" : "Inactive")</p>
                <p><strong>Greeting:</strong> @ViewData["Greeting"]</p>
            </div>
        </div>
    </section>
}
