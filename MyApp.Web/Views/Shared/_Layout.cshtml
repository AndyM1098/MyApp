<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" asp-controller="Home" asp-action="Index">MyApp</a>
            <nav class="site-nav" aria-label="Primary">
                <a class="@(currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">Intro</a>
                <a class="@(currentAction == "Projects" ? "active" : "")" asp-controller="Home" asp-action="Projects">Projects</a>
                <a class="@(currentAction == "About" ? "active" : "")" asp-controller="Home" asp-action="About">About</a>
            </nav>
        </div>
    </header>

    <main role="main" class="page-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; @DateTime.Now.Year MyApp. Built with ASP.NET Core.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
